# Raw DNA input data — never commit (sensitive personal data + large binary files)
data/input_data/

# Analysis outputs — contain derived personal genetic data, never commit
output/

# Large binary cache and chunk files
data/output_data/*.pkl
data/output_data/*.npy

# Python virtual environment
venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# macOS
.DS_Store
**/.DS_Store

# Logs (keep log files in output/ for reference, but ignore root-level logs)
*.log

# Jupyter
.ipynb_checkpoints/

# Environment variables — keep the example, ignore real values
.env
.env.local
.dev.vars

# Wrangler local state
.wrangler/
workers/**/.wrangler/

# Editor
.vscode/
.idea/
*.swp
*.swo
