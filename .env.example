# Cloudflare R2 — copy to .env and fill in real values
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API tokens

R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kinection

# Analysis mode — set to 1 to read/write data via R2 instead of local disk
USE_R2=0

# Job identifier — set per-analysis-run (provided by the Workers API in production)
JOB_ID=dev

# Compute service auth — used by the Workers queue consumer to call this service
COMPUTE_API_KEY=
