# Cloudflare R2 — copy to .env and fill in real values
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API tokens

R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kinection

# Cloudflare Worker API URL (set after deploying the Worker)
WORKER_API_URL=https://kinection-api.<your-subdomain>.workers.dev

# Shared secret — must match the value set via `wrangler secret put COMPUTE_API_KEY`
COMPUTE_API_KEY=

# Analysis mode — set to 1 to read/write AADR data and results via R2
USE_R2=1

# Job identifier — set automatically by the daemon per job; override for local dev
JOB_ID=dev

# How often the daemon polls for queued jobs (seconds)
POLL_INTERVAL=5
